{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build all",
            "group": "build",
            "type": "shell",
            "command": "make",
            "args": [
                "all"
            ]
        },
        {
            "label": "Build clean ",
            "group": "build",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ]
        },
        {
            "label": "clean & build ",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "type": "shell",
            "command": "make",
            "args": [
                "clean",
                "all"
            ],
            "problemMatcher": []
        },
        {
            "label": "flash",
            "type": "shell",
            "command": "C:\\dev\\tools\\opencd\\bin\\openocd.exe",
            "args": [
                "-f",
                "C:\\dev\\tools\\opencd\\openocd\\scripts\\interface\\stlink.cfg",
                "-f",
                "C:\\dev\\tools\\opencd\\openocd\\scripts\\target\\stm32wbx.cfg",
                "-c",
                "program ./build/LIA_26.elf verify reset exit"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "detail": "Flashes the firmware to the target using OpenOCD"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "arm-none-eabi-gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.elf"
            ],
            "options": {
                "cwd": "$(workspaceFolder)"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Task generated by Debugger."
        },

    ]
}