 153:Core/Src/main.c ****     {
 154:Core/Src/main.c ****       case STATE_1:
 155:Core/Src/main.c ****         HAL_GPIO_TogglePin(GPIOB, LED_R_Pin);
 156:Core/Src/main.c ****         HAL_GPIO_WritePin(GPIOB, LED_B_Pin, 0);
 157:Core/Src/main.c ****         HAL_GPIO_WritePin(GPIOB, LED_G_Pin, 0);
 158:Core/Src/main.c ****         break;
 159:Core/Src/main.c ****       case STATE_2:
 160:Core/Src/main.c **** 
 161:Core/Src/main.c ****         if (tastScheduler >= 1){
 162:Core/Src/main.c ****           packageDataToMem();
 163:Core/Src/main.c ****           sendPackageToMem();
 164:Core/Src/main.c **** 
 165:Core/Src/main.c ****           HAL_GPIO_WritePin(GPIOB, LED_B_Pin, 0);
 166:Core/Src/main.c ****           HAL_GPIO_WritePin(GPIOB, LED_R_Pin, 0);  
 167:Core/Src/main.c ****           HAL_GPIO_WritePin(GPIOB, LED_G_Pin, 1);
 168:Core/Src/main.c ****           tastScheduler = 0;
 169:Core/Src/main.c ****         }
 170:Core/Src/main.c ****         break;
 171:Core/Src/main.c ****       case STATE_3:
 172:Core/Src/main.c ****         if(Custom_STN_NotificationEnabled())
 173:Core/Src/main.c ****         {
 174:Core/Src/main.c ****           readMemSendBle();
 175:Core/Src/main.c ****         }
 176:Core/Src/main.c **** 
 177:Core/Src/main.c ****         HAL_GPIO_WritePin(GPIOB, LED_B_Pin, 1);
 178:Core/Src/main.c ****         HAL_GPIO_WritePin(GPIOB, LED_R_Pin, 0);  
 179:Core/Src/main.c ****         HAL_GPIO_WritePin(GPIOB, LED_G_Pin, 0);
 180:Core/Src/main.c ****         break;
 181:Core/Src/main.c ****     }
 182:Core/Src/main.c ****     /* USER CODE END WHILE */
