 150:Core/Src/bme280.c **** /* measure the temp, pressure and humidity
 151:Core/Src/bme280.c ****  * the values will be stored in the parameters passed to the function
 152:Core/Src/bme280.c ****  */
 153:Core/Src/bme280.c **** void BME280_Measure(float *temperature, float *pressure, float *humidity)
 154:Core/Src/bme280.c **** {
 155:Core/Src/bme280.c **** 
 156:Core/Src/bme280.c **** 	//printf("ChipID: %x\n", chipID);
 157:Core/Src/bme280.c **** 
 158:Core/Src/bme280.c ****     if (BMEReadRaw() == 0)
 159:Core/Src/bme280.c ****     {
 160:Core/Src/bme280.c ****         if (tRaw == 0x800000) *temperature = 0; // temp disabled
 161:Core/Src/bme280.c ****         else
 162:Core/Src/bme280.c ****             *temperature = (BME280_compensate_T_int32(tRaw)) / 100.0f;
 163:Core/Src/bme280.c **** 
 164:Core/Src/bme280.c ****         if (pRaw == 0x800000) *pressure = 0; // pressure disabled
 165:Core/Src/bme280.c ****         else
 166:Core/Src/bme280.c ****         {
 167:Core/Src/bme280.c **** #if SUPPORT_64BIT
 168:Core/Src/bme280.c ****             *pressure = (BME280_compensate_P_int64(pRaw)) / 256.0f;
 169:Core/Src/bme280.c **** #elif SUPPORT_32BIT
 170:Core/Src/bme280.c ****             *pressure = (BME280_compensate_P_int32(pRaw));  // in Pa
 171:Core/Src/bme280.c **** #endif
 172:Core/Src/bme280.c ****         }
 173:Core/Src/bme280.c **** 
 174:Core/Src/bme280.c ****         if (hRaw == 0x8000) *humidity = 0; // humidity disabled
 175:Core/Src/bme280.c ****         else
 176:Core/Src/bme280.c ****             *humidity = (bme280_compensate_H_int32(hRaw)) / 1024.0f;
 177:Core/Src/bme280.c ****     }
 178:Core/Src/bme280.c ****     else
 179:Core/Src/bme280.c ****     {
 180:Core/Src/bme280.c ****         // if the device is detached
 181:Core/Src/bme280.c ****         *temperature = 0;
 182:Core/Src/bme280.c ****         *pressure    = 0;
 183:Core/Src/bme280.c ****         *humidity    = 0;
 184:Core/Src/bme280.c **** 
 185:Core/Src/bme280.c ****     }
 186:Core/Src/bme280.c **** }
