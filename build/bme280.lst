  90:Core/Src/bme280.c **** 	{
  91:Core/Src/bme280.c **** 		return 3;  //error NUM for debug
  92:Core/Src/bme280.c **** 	}
  93:Core/Src/bme280.c **** 	HAL_Delay (100);
  94:Core/Src/bme280.c **** 	HAL_I2C_Mem_Read(&BME280_I2C, BME280_ADDRESS, CTRL_HUM_REG, 1, &datacheck, 1, 1000);
