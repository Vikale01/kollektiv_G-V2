 188:Core/Src/bme280.c **** 
 189:Core/Src/bme280.c **** // Read the Trimming parameters saved in the NVM ROM of the device
 190:Core/Src/bme280.c **** static int TrimRead(void)
 191:Core/Src/bme280.c **** {
 192:Core/Src/bme280.c **** 	uint8_t trimdata[32];
 193:Core/Src/bme280.c **** 
 194:Core/Src/bme280.c **** 	// Read NVM from 0x88 to 0xA1 (25 bytes)
 195:Core/Src/bme280.c **** 	if (HAL_I2C_Mem_Read(&BME280_I2C, BME280_ADDRESS, 0x88, 1, trimdata, 25, HAL_MAX_DELAY) != HAL_OK)
 196:Core/Src/bme280.c **** 	{
 197:Core/Src/bme280.c **** 			return 1;  //error NUM for debug
 198:Core/Src/bme280.c **** 	}
 199:Core/Src/bme280.c **** 
 200:Core/Src/bme280.c **** 	// Read NVM from 0xE1 to 0xE7 (7 bytes)
 201:Core/Src/bme280.c **** 	if (HAL_I2C_Mem_Read(&BME280_I2C, BME280_ADDRESS, 0xE1, 1, trimdata + 25, 7, HAL_MAX_DELAY) != HAL
ARM GAS  C:\Users\bku598\AppData\Local\Temp\ccXIK56B.s 			page 5


 202:Core/Src/bme280.c **** 	{
 203:Core/Src/bme280.c **** 		return 2;  //error NUM for debug
 204:Core/Src/bme280.c **** 	}
 205:Core/Src/bme280.c **** 
 206:Core/Src/bme280.c **** 	// Temperature coefficients
 207:Core/Src/bme280.c **** 	dig_T1 = (uint16_t)(trimdata[1] << 8 | trimdata[0]);
 208:Core/Src/bme280.c **** 	dig_T2 = (int16_t)(trimdata[3] << 8 | trimdata[2]);
 209:Core/Src/bme280.c **** 	dig_T3 = (int16_t)(trimdata[5] << 8 | trimdata[4]);
 210:Core/Src/bme280.c **** 
 211:Core/Src/bme280.c **** 	// Pressure coefficients
 212:Core/Src/bme280.c **** 	dig_P1 = (uint16_t)(trimdata[7] << 8 | trimdata[6]);
 213:Core/Src/bme280.c **** 	dig_P2 = (int16_t)(trimdata[9] << 8 | trimdata[8]);
 214:Core/Src/bme280.c **** 	dig_P3 = (int16_t)(trimdata[11] << 8 | trimdata[10]);
 215:Core/Src/bme280.c **** 	dig_P4 = (int16_t)(trimdata[13] << 8 | trimdata[12]);
 216:Core/Src/bme280.c **** 	dig_P5 = (int16_t)(trimdata[15] << 8 | trimdata[14]);
 217:Core/Src/bme280.c **** 	dig_P6 = (int16_t)(trimdata[17] << 8 | trimdata[16]);
 218:Core/Src/bme280.c **** 	dig_P7 = (int16_t)(trimdata[19] << 8 | trimdata[18]);
 219:Core/Src/bme280.c **** 	dig_P8 = (int16_t)(trimdata[21] << 8 | trimdata[20]);
 220:Core/Src/bme280.c **** 	dig_P9 = (int16_t)(trimdata[23] << 8 | trimdata[22]);
 221:Core/Src/bme280.c **** 
 222:Core/Src/bme280.c **** 	// Humidity coefficients
 223:Core/Src/bme280.c **** 	dig_H1 = trimdata[24];
 224:Core/Src/bme280.c **** 	dig_H2 = (int16_t)(trimdata[26] << 8 | trimdata[25]);
 225:Core/Src/bme280.c **** 	dig_H3 = trimdata[27];
 226:Core/Src/bme280.c **** 	dig_H4 = (int16_t)((trimdata[28] << 4) | (trimdata[29] & 0x0f));
 227:Core/Src/bme280.c **** 	dig_H5 = (int16_t)((trimdata[30] << 4) | (trimdata[29] >> 4));
 228:Core/Src/bme280.c **** 	dig_H6 = (int8_t)trimdata[31];
 229:Core/Src/bme280.c **** 
 230:Core/Src/bme280.c **** 	return 0; //Success
 231:Core/Src/bme280.c **** }
 232:Core/Src/bme280.c **** 
 233:Core/Src/bme280.c **** static int BMEReadRaw(void)
 234:Core/Src/bme280.c **** {
 235:Core/Src/bme280.c **** 	uint8_t RawData[8];
 236:Core/Src/bme280.c **** 
 237:Core/Src/bme280.c **** 	// Check the chip ID before reading
 238:Core/Src/bme280.c **** 	HAL_I2C_Mem_Read(&hi2c1, BME280_ADDRESS, ID_REG, 1, &chipID, 1, 1000);
 239:Core/Src/bme280.c **** 	if (chipID == 0x60)
 240:Core/Src/bme280.c **** 	{
 241:Core/Src/bme280.c **** 		// Read the Registers 0xF7 to 0xFE
 242:Core/Src/bme280.c **** 		HAL_I2C_Mem_Read(&BME280_I2C, BME280_ADDRESS, PRESS_MSB_REG, 1, RawData, 8, HAL_MAX_DELAY);
 243:Core/Src/bme280.c **** 
 244:Core/Src/bme280.c **** 		/* Calculate the Raw data for the parameters
 245:Core/Src/bme280.c **** 		 * Here the Pressure and Temperature are in 20 bit format and humidity in 16 bit format
 246:Core/Src/bme280.c **** 		 */
 247:Core/Src/bme280.c **** 		pRaw = (RawData[0]<<12)|(RawData[1]<<4)|(RawData[2]>>4);
 248:Core/Src/bme280.c **** 		tRaw = (RawData[3]<<12)|(RawData[4]<<4)|(RawData[5]>>4);
 249:Core/Src/bme280.c **** 		hRaw = (RawData[6]<<8)|(RawData[7]);
 250:Core/Src/bme280.c **** 
 251:Core/Src/bme280.c **** 		return 0;
 252:Core/Src/bme280.c **** 	}
 253:Core/Src/bme280.c **** 
 254:Core/Src/bme280.c **** 	else return 1;  //error NUM for debug
 255:Core/Src/bme280.c **** }
 256:Core/Src/bme280.c **** 
 257:Core/Src/bme280.c **** void BME280_ReadMeasurement_Raw(uint8_t Rawdata[8])
 258:Core/Src/bme280.c **** {
ARM GAS  C:\Users\bku598\AppData\Local\Temp\ccXIK56B.s 			page 6


 259:Core/Src/bme280.c **** 	// Check the chip ID before reading
 260:Core/Src/bme280.c **** 	HAL_I2C_Mem_Read(&hi2c1, BME280_ADDRESS, ID_REG, 1, &chipID, 1, 1000);
 261:Core/Src/bme280.c **** 	if (chipID == 0x60)
 262:Core/Src/bme280.c **** 	{
 263:Core/Src/bme280.c **** 		// Read the Registers 0xF7 to 0xFE
 264:Core/Src/bme280.c **** 		HAL_I2C_Mem_Read(&BME280_I2C, BME280_ADDRESS, PRESS_MSB_REG, 1, Rawdata, 8, HAL_MAX_DELAY);
 265:Core/Src/bme280.c **** 	}	
 266:Core/Src/bme280.c **** }
