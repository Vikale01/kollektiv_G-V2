  47:Core/Src/bme280.c **** /* Configuration for the BME280
  48:Core/Src/bme280.c **** 
  49:Core/Src/bme280.c ****  * @osrs is the oversampling to improve the accuracy
  50:Core/Src/bme280.c ****  *       if osrs is set to OSRS_OFF, the respective measurement will be skipped
  51:Core/Src/bme280.c ****  *       It can be set to OSRS_1, OSRS_2, OSRS_4, etc. Check the header file
  52:Core/Src/bme280.c ****  *
  53:Core/Src/bme280.c ****  * @mode can be used to set the mode for the device
  54:Core/Src/bme280.c ****  *       MODE_SLEEP will put the device in sleep
  55:Core/Src/bme280.c ****  *       MODE_FORCED device goes back to sleep after one measurement. You need to use the BME280_Wa
  56:Core/Src/bme280.c ****  *       MODE_NORMAL device performs measurement in the normal mode. Check datasheet page no 16
  57:Core/Src/bme280.c ****  *
  58:Core/Src/bme280.c ****  * @t_sb is the standby time. The time sensor waits before performing another measurement
  59:Core/Src/bme280.c ****  *       It is used along with the normal mode. Check datasheet page no 16 and page no 30
  60:Core/Src/bme280.c ****  *
  61:Core/Src/bme280.c ****  * @filter is the IIR filter coefficients
  62:Core/Src/bme280.c ****  *         IIR is used to avoid the short term fluctuations
  63:Core/Src/bme280.c ****  *         Check datasheet page no 18 and page no 30
  64:Core/Src/bme280.c ****  */
  65:Core/Src/bme280.c **** 
  66:Core/Src/bme280.c **** int BME280_Config (uint8_t osrs_t, uint8_t osrs_p, uint8_t osrs_h, uint8_t mode, uint8_t t_sb, uint
  67:Core/Src/bme280.c **** {
  68:Core/Src/bme280.c **** 	// Read the Trimming parameters
  69:Core/Src/bme280.c **** 	if (TrimRead() != 0)
  70:Core/Src/bme280.c **** 	{
  71:Core/Src/bme280.c **** 		return 1;
  72:Core/Src/bme280.c **** 	}
  73:Core/Src/bme280.c **** 
  74:Core/Src/bme280.c **** 	uint8_t datatowrite = 0;
  75:Core/Src/bme280.c **** 	uint8_t datacheck = 0;
  76:Core/Src/bme280.c **** 
  77:Core/Src/bme280.c **** 	// Reset the device
  78:Core/Src/bme280.c **** 	datatowrite = 0xB6;  // reset sequence
  79:Core/Src/bme280.c **** 	if (HAL_I2C_Mem_Write(&BME280_I2C, BME280_ADDRESS, RESET_REG, 1, &datatowrite, 1, 1000) != HAL_OK)
  80:Core/Src/bme280.c **** 	{
  81:Core/Src/bme280.c **** 		return 2;  //error NUM for debug
  82:Core/Src/bme280.c **** 	}
  83:Core/Src/bme280.c **** 
  84:Core/Src/bme280.c **** 	HAL_Delay (100);
  85:Core/Src/bme280.c **** 
  86:Core/Src/bme280.c **** 
  87:Core/Src/bme280.c **** 	// write the humidity oversampling to 0xF2
ARM GAS  C:\Users\bku598\AppData\Local\Temp\ccXIK56B.s 			page 3


