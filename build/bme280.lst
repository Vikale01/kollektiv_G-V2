 131:Core/Src/bme280.c **** /* To be used when doing the force measurement
 132:Core/Src/bme280.c ****  * the Device need to be put in forced mode every time the measurement is needed
 133:Core/Src/bme280.c ****  */
 134:Core/Src/bme280.c **** void BME280_WakeUP(void)
 135:Core/Src/bme280.c **** {
 136:Core/Src/bme280.c **** 	uint8_t datatowrite = 0;
 137:Core/Src/bme280.c **** 
 138:Core/Src/bme280.c **** 	// first read the register
 139:Core/Src/bme280.c **** 	HAL_I2C_Mem_Read(&BME280_I2C, BME280_ADDRESS, CTRL_MEAS_REG, 1, &datatowrite, 1, 1000);
 140:Core/Src/bme280.c **** 
 141:Core/Src/bme280.c **** 	// modify the data with the forced mode
 142:Core/Src/bme280.c **** 	datatowrite = datatowrite | MODE_FORCED;
 143:Core/Src/bme280.c **** 
 144:Core/Src/bme280.c **** 	// write the new data to the register
ARM GAS  C:\Users\bku598\AppData\Local\Temp\ccXIK56B.s 			page 4


 145:Core/Src/bme280.c **** 	HAL_I2C_Mem_Write(&BME280_I2C, BME280_ADDRESS, CTRL_MEAS_REG, 1, &datatowrite, 1, 1000);
 146:Core/Src/bme280.c **** 
 147:Core/Src/bme280.c **** 	HAL_Delay (100);
 148:Core/Src/bme280.c **** }
