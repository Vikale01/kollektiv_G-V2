  37:Core/Src/freertos_port.c **** #ifndef configSYSTICK_CLOCK_HZ
  38:Core/Src/freertos_port.c **** #define configSYSTICK_CLOCK_HZ configCPU_CLOCK_HZ
  39:Core/Src/freertos_port.c **** /* Ensure the SysTick is clocked at the same frequency as the core. */
  40:Core/Src/freertos_port.c **** #define portNVIC_SYSTICK_CLK_BIT        ( 1UL << 2UL )
  41:Core/Src/freertos_port.c **** #else
  42:Core/Src/freertos_port.c **** /* The way the SysTick is clocked is not modified in case it is not the same
  43:Core/Src/freertos_port.c ****         as the core. */
  44:Core/Src/freertos_port.c **** #define portNVIC_SYSTICK_CLK_BIT        ( 0 )
  45:Core/Src/freertos_port.c **** #endif
  46:Core/Src/freertos_port.c **** 
  47:Core/Src/freertos_port.c **** #define CPU_CLOCK_KHZ   ( configCPU_CLOCK_HZ / 1000 )
  48:Core/Src/freertos_port.c **** 
  49:Core/Src/freertos_port.c **** /* Constants required to manipulate the core.  Registers first... */
  50:Core/Src/freertos_port.c **** #define portNVIC_SYSTICK_CTRL_REG               ( * ( ( volatile uint32_t * ) 0xe000e010 ) )
  51:Core/Src/freertos_port.c **** #define portNVIC_SYSTICK_LOAD_REG               ( * ( ( volatile uint32_t * ) 0xe000e014 ) )
  52:Core/Src/freertos_port.c **** #define portNVIC_SYSTICK_CURRENT_VALUE_REG      ( * ( ( volatile uint32_t * ) 0xe000e018 ) )
  53:Core/Src/freertos_port.c **** #define portNVIC_SYSTICK_INT_BIT                ( 1UL << 1UL )
  54:Core/Src/freertos_port.c **** #define portNVIC_SYSTICK_ENABLE_BIT             ( 1UL << 0UL )
  55:Core/Src/freertos_port.c **** #define portNVIC_SYSTICK_COUNT_FLAG_BIT         ( 1UL << 16UL )
  56:Core/Src/freertos_port.c **** 
