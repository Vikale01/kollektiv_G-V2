  89:Core/Src/freertos_port.c ****   /* If low power is not used, do not stop the SysTick and continue execution */
  90:Core/Src/freertos_port.c **** #if ( CFG_LPM_SUPPORTED != 0)
  91:Core/Src/freertos_port.c ****   /**
  92:Core/Src/freertos_port.c ****    * Although this is not documented as such, when xExpectedIdleTime = 0xFFFFFFFF = (~0),
  93:Core/Src/freertos_port.c ****    * it likely means the system may enter low power for ever ( from a FreeRTOS point of view ).
  94:Core/Src/freertos_port.c ****    * Otherwise, for a FreeRTOS tick set to 1ms, that would mean it is requested to wakeup in 8 year
  95:Core/Src/freertos_port.c ****    * When the system may enter low power mode for ever, FreeRTOS is not really interested to mainta
  96:Core/Src/freertos_port.c ****    * systick count and when the system exits from low power mode, there is no need to update the co
  97:Core/Src/freertos_port.c ****    * the time spent in low power mode
  98:Core/Src/freertos_port.c ****    */
  99:Core/Src/freertos_port.c ****     uint32_t ulCompleteTickPeriods;
 100:Core/Src/freertos_port.c **** 
 101:Core/Src/freertos_port.c ****   /* Stop the SysTick  to avoid the interrupt to occur while in the critical section.
 102:Core/Src/freertos_port.c ****    * Otherwise, this will prevent the device to enter low power mode
 103:Core/Src/freertos_port.c ****    * At this time, an update of the systick will not be considered
 104:Core/Src/freertos_port.c ****    *
 105:Core/Src/freertos_port.c ****    */
 106:Core/Src/freertos_port.c ****   portNVIC_SYSTICK_CTRL_REG &= ~portNVIC_SYSTICK_ENABLE_BIT;
 107:Core/Src/freertos_port.c **** 
 108:Core/Src/freertos_port.c ****   /* Enter a critical section but don't use the taskENTER_CRITICAL()
 109:Core/Src/freertos_port.c ****         method as that will mask interrupts that should exit sleep mode. */
 110:Core/Src/freertos_port.c ****   __disable_irq();
 111:Core/Src/freertos_port.c ****   __DSB();
 112:Core/Src/freertos_port.c ****   __ISB();
 113:Core/Src/freertos_port.c **** 
 114:Core/Src/freertos_port.c ****   /* If a context switch is pending or a task is waiting for the scheduler
 115:Core/Src/freertos_port.c ****         to be unsuspended then abandon the low power entry. */
 116:Core/Src/freertos_port.c ****   if( eTaskConfirmSleepModeStatus() == eAbortSleep )
 117:Core/Src/freertos_port.c ****   {
 118:Core/Src/freertos_port.c ****     /* Restart SysTick. */
 119:Core/Src/freertos_port.c ****     portNVIC_SYSTICK_CTRL_REG |= portNVIC_SYSTICK_ENABLE_BIT;
 120:Core/Src/freertos_port.c **** 
 121:Core/Src/freertos_port.c ****     /* Re-enable interrupts - see comments above __disable_interrupt()
 122:Core/Src/freertos_port.c ****                 call above. */
 123:Core/Src/freertos_port.c ****     __enable_irq();
 124:Core/Src/freertos_port.c ****   }
 125:Core/Src/freertos_port.c ****   else
 126:Core/Src/freertos_port.c ****   {
 127:Core/Src/freertos_port.c ****     if (xExpectedIdleTime != (~0))
 128:Core/Src/freertos_port.c ****     {
 129:Core/Src/freertos_port.c ****       /* Remove one tick to wake up before the event occurs */
 130:Core/Src/freertos_port.c ****       xExpectedIdleTime--;
 131:Core/Src/freertos_port.c ****       /* Start the low power timer */
 132:Core/Src/freertos_port.c ****       LpTimerStart( xExpectedIdleTime );
 133:Core/Src/freertos_port.c ****     }
 134:Core/Src/freertos_port.c **** 
 135:Core/Src/freertos_port.c ****     /* Enter low power mode */
 136:Core/Src/freertos_port.c ****     LpEnter( );
 137:Core/Src/freertos_port.c **** 
 138:Core/Src/freertos_port.c ****     if (xExpectedIdleTime != (~0))
ARM GAS  C:\Users\bku598\AppData\Local\Temp\ccjnWHed.s 			page 4


 139:Core/Src/freertos_port.c ****     {
 140:Core/Src/freertos_port.c ****       /**
 141:Core/Src/freertos_port.c ****        * Get the number of FreeRTOS ticks that has been suppressed
 142:Core/Src/freertos_port.c ****        * In the current implementation, this shall be kept in critical section
 143:Core/Src/freertos_port.c ****        * so that the timer server return the correct elapsed time
 144:Core/Src/freertos_port.c ****        */
 145:Core/Src/freertos_port.c ****       ulCompleteTickPeriods = LpGetElapsedTime( );
 146:Core/Src/freertos_port.c ****       vTaskStepTick( ulCompleteTickPeriods );
 147:Core/Src/freertos_port.c ****     }
 148:Core/Src/freertos_port.c **** 
 149:Core/Src/freertos_port.c ****     /* Restart SysTick */
 150:Core/Src/freertos_port.c ****     portNVIC_SYSTICK_CURRENT_VALUE_REG = 0UL;
 151:Core/Src/freertos_port.c ****     portNVIC_SYSTICK_CTRL_REG |= portNVIC_SYSTICK_ENABLE_BIT;
 152:Core/Src/freertos_port.c ****     portNVIC_SYSTICK_LOAD_REG = ulTimerCountsForOneTick - 1UL;
 153:Core/Src/freertos_port.c **** 
 154:Core/Src/freertos_port.c ****     /* Exit with interrUpts enabled. */
 155:Core/Src/freertos_port.c ****     __enable_irq();
 156:Core/Src/freertos_port.c ****   }
 157:Core/Src/freertos_port.c **** #endif
 158:Core/Src/freertos_port.c **** }
