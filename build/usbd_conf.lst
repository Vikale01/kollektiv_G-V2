 259:USB_Device/Target/usbd_conf.c ****   * @brief  Suspend callback.
 260:USB_Device/Target/usbd_conf.c ****   * When Low power mode is enabled the debug cannot be used (IAR, Keil doesn't support it)
 261:USB_Device/Target/usbd_conf.c ****   * @param  hpcd: PCD handle
 262:USB_Device/Target/usbd_conf.c ****   * @retval None
 263:USB_Device/Target/usbd_conf.c ****   */
 264:USB_Device/Target/usbd_conf.c **** #if (USE_HAL_PCD_REGISTER_CALLBACKS == 1U)
 265:USB_Device/Target/usbd_conf.c **** static void PCD_SuspendCallback(PCD_HandleTypeDef *hpcd)
 266:USB_Device/Target/usbd_conf.c **** #else
 267:USB_Device/Target/usbd_conf.c **** void HAL_PCD_SuspendCallback(PCD_HandleTypeDef *hpcd)
 268:USB_Device/Target/usbd_conf.c **** #endif /* USE_HAL_PCD_REGISTER_CALLBACKS */
 269:USB_Device/Target/usbd_conf.c **** {
 270:USB_Device/Target/usbd_conf.c ****   /* USER CODE BEGIN HAL_PCD_SuspendCallback_PreTreatment */
 271:USB_Device/Target/usbd_conf.c **** 
 272:USB_Device/Target/usbd_conf.c ****   /* USER CODE END HAL_PCD_SuspendCallback_PreTreatment */
 273:USB_Device/Target/usbd_conf.c ****   /* Inform USB library that core enters in suspend Mode. */
 274:USB_Device/Target/usbd_conf.c ****   USBD_LL_Suspend((USBD_HandleTypeDef*)hpcd->pData);
 275:USB_Device/Target/usbd_conf.c ****   /* Enter in STOP mode. */
 276:USB_Device/Target/usbd_conf.c ****   /* USER CODE BEGIN 2 */
 277:USB_Device/Target/usbd_conf.c ****   if (hpcd->Init.low_power_enable)
 278:USB_Device/Target/usbd_conf.c ****   {
 279:USB_Device/Target/usbd_conf.c ****     /* Set SLEEPDEEP bit and SleepOnExit of Cortex System Control Register. */
 280:USB_Device/Target/usbd_conf.c ****     SCB->SCR |= (uint32_t)((uint32_t)(SCB_SCR_SLEEPDEEP_Msk | SCB_SCR_SLEEPONEXIT_Msk));
