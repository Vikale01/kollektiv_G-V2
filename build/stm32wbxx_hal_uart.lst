2778:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****      (+) HAL_UART_ReceiverTimeout_Config() API allows to configure the receiver timeout value on th
2779:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****      (+) HAL_UART_EnableReceiverTimeout() API enables the receiver timeout feature
2780:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****      (+) HAL_UART_DisableReceiverTimeout() API disables the receiver timeout feature
2781:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****      (+) HAL_MultiProcessor_EnableMuteMode() API enables mute mode
2782:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****      (+) HAL_MultiProcessor_DisableMuteMode() API disables mute mode
2783:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****      (+) HAL_MultiProcessor_EnterMuteMode() API enters mute mode
2784:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****      (+) UART_SetConfig() API configures the UART peripheral
2785:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****      (+) UART_AdvFeatureConfig() API optionally configures the UART advanced features
ARM GAS  C:\Users\bku598\AppData\Local\Temp\ccXbpguR.s 			page 54


