 264:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****         (++) TX and/or RX pin level inversion
 265:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****         (++) data logical level inversion
 266:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****         (++) RX and TX pins swap
 267:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****         (++) RX overrun detection disabling
 268:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****         (++) DMA disabling on RX error
 269:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****         (++) MSB first on communication line
 270:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_uart.c ****         (++) auto Baud rate detection
