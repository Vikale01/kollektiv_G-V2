 183:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c **** #else
 184:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c ****   if (hrng->State == HAL_RNG_STATE_RESET)
 185:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c ****   {
