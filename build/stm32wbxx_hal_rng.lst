 165:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c **** 
 166:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c **** #if (USE_HAL_RNG_REGISTER_CALLBACKS == 1)
 167:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c ****   if (hrng->State == HAL_RNG_STATE_RESET)
 168:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c ****   {
