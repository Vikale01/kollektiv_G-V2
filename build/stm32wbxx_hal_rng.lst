 155:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c **** HAL_StatusTypeDef HAL_RNG_Init(RNG_HandleTypeDef *hrng)
 156:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c **** {
 157:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c ****   /* Check the RNG handle allocation */
 158:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_rng.c ****   if (hrng == NULL)
