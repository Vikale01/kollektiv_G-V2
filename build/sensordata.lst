  93:Core/Src/sensordata.c **** 
  94:Core/Src/sensordata.c **** void sendPackageToMem(void)
  95:Core/Src/sensordata.c **** {
  96:Core/Src/sensordata.c ****   if(!bufferFull){return;}
  97:Core/Src/sensordata.c **** 
  98:Core/Src/sensordata.c ****   newSectionCheck();  // Check if we are in a new section in the memory (One section is 4096 bytes)
  99:Core/Src/sensordata.c **** 
 100:Core/Src/sensordata.c ****   buffer[BUFFER_SIZE - 4] = (addInc >> 24) & 0xFF;
 101:Core/Src/sensordata.c ****   buffer[BUFFER_SIZE - 3] = (addInc >> 16) & 0xFF;
 102:Core/Src/sensordata.c ****   buffer[BUFFER_SIZE - 2] = (addInc >> 8) & 0xFF;
 103:Core/Src/sensordata.c ****   buffer[BUFFER_SIZE - 1] = addInc & 0xFF;
 104:Core/Src/sensordata.c **** 
 105:Core/Src/sensordata.c ****   Flash_WritePage((sectorCounter * SECTION_SIZE) + (BUFFER_SIZE * pageCounter), buffer, BUFFER_SIZE
 106:Core/Src/sensordata.c **** 
 107:Core/Src/sensordata.c ****   pageCounter++;
 108:Core/Src/sensordata.c ****   addInc++;
 109:Core/Src/sensordata.c **** 
 110:Core/Src/sensordata.c ****   bufferPointer = 0;
 111:Core/Src/sensordata.c ****   dataCounter = 0;
 112:Core/Src/sensordata.c ****   bufferFull = false;
 113:Core/Src/sensordata.c ****   memset(buffer, 0xFF, BUFFER_SIZE);
 114:Core/Src/sensordata.c **** }
