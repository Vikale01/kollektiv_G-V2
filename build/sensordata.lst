 116:Core/Src/sensordata.c **** // Function to find the last written page in flash
 117:Core/Src/sensordata.c **** void findStartPos(void)
 118:Core/Src/sensordata.c **** {
 119:Core/Src/sensordata.c ****     for (uint32_t i = 0; i < PAGE_IN_MEMORY; i++)
 120:Core/Src/sensordata.c ****     {
 121:Core/Src/sensordata.c ****         Flash_4ByteRead(i * BUFFER_SIZE, readBuffer, BUFFER_SIZE);
 122:Core/Src/sensordata.c **** 
 123:Core/Src/sensordata.c ****         uint32_t pageId = ((uint32_t)readBuffer[BUFFER_SIZE-4] << 24) |
 124:Core/Src/sensordata.c ****                           ((uint32_t)readBuffer[BUFFER_SIZE-3] << 16) |
 125:Core/Src/sensordata.c ****                           ((uint32_t)readBuffer[BUFFER_SIZE-2] << 8)  |
 126:Core/Src/sensordata.c ****                           ((uint32_t)readBuffer[BUFFER_SIZE-1]);
 127:Core/Src/sensordata.c **** 
 128:Core/Src/sensordata.c ****         if (pageId == 0xFFFFFFFF)
 129:Core/Src/sensordata.c ****         {
 130:Core/Src/sensordata.c ****             if (i == 0)
 131:Core/Src/sensordata.c ****             {
 132:Core/Src/sensordata.c ****                 // Flash is empty
 133:Core/Src/sensordata.c ****                 addInc = 0;
 134:Core/Src/sensordata.c ****                 pageCounter = 0;
 135:Core/Src/sensordata.c ****                 sectorCounter = 0;
 136:Core/Src/sensordata.c ****             }
 137:Core/Src/sensordata.c ****             else
 138:Core/Src/sensordata.c ****             {
 139:Core/Src/sensordata.c **** 
 140:Core/Src/sensordata.c ****                 Flash_4ByteRead((i - 1) * BUFFER_SIZE, readBuffer, BUFFER_SIZE);
 141:Core/Src/sensordata.c **** 
 142:Core/Src/sensordata.c ****                 uint32_t pageId = ((uint32_t)readBuffer[BUFFER_SIZE-4] << 24) |
ARM GAS  C:\Users\bku598\AppData\Local\Temp\ccjmfozw.s 			page 6


 143:Core/Src/sensordata.c ****                                   ((uint32_t)readBuffer[BUFFER_SIZE-3] << 16) |
 144:Core/Src/sensordata.c ****                                   ((uint32_t)readBuffer[BUFFER_SIZE-2] << 8)  |
 145:Core/Src/sensordata.c ****                                   ((uint32_t)readBuffer[BUFFER_SIZE-1]);
 146:Core/Src/sensordata.c **** 
 147:Core/Src/sensordata.c ****                 // Last written page is i-1
 148:Core/Src/sensordata.c ****                 addInc = pageId + 1; // optional: continue numbering
 149:Core/Src/sensordata.c ****                 pageCounter = (i % PAGE_PER_SECTION);
 150:Core/Src/sensordata.c ****                 sectorCounter = (i / PAGE_PER_SECTION);
 151:Core/Src/sensordata.c ****             }
 152:Core/Src/sensordata.c ****             return;
 153:Core/Src/sensordata.c ****         }
 154:Core/Src/sensordata.c ****     }
 155:Core/Src/sensordata.c **** 
 156:Core/Src/sensordata.c ****     // All pages used
 157:Core/Src/sensordata.c ****     addInc = PAGE_IN_MEMORY;
 158:Core/Src/sensordata.c ****     pageCounter = PAGE_IN_MEMORY % PAGE_PER_SECTION;
 159:Core/Src/sensordata.c ****     sectorCounter = PAGE_IN_MEMORY / PAGE_PER_SECTION;
 160:Core/Src/sensordata.c **** }
