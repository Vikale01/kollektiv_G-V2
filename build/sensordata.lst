  44:Core/Src/sensordata.c **** static void sendPage_ble(uint8_t pageBuffer[256]) 
  45:Core/Src/sensordata.c **** { 
  46:Core/Src/sensordata.c ****     tBleStatus status;
  47:Core/Src/sensordata.c **** 
  48:Core/Src/sensordata.c ****     // send first 128 bytes
  49:Core/Src/sensordata.c ****     do {
  50:Core/Src/sensordata.c ****         status = Custom_STM_App_Update_Char_Variable_Length(CUSTOM_STM_DP, pageBuffer, 128);
  51:Core/Src/sensordata.c ****         if(status != BLE_STATUS_SUCCESS)
  52:Core/Src/sensordata.c ****             HAL_Delay(10);
  53:Core/Src/sensordata.c ****     } while(status != BLE_STATUS_SUCCESS);
  54:Core/Src/sensordata.c **** 
  55:Core/Src/sensordata.c ****     // send second 128 bytes
  56:Core/Src/sensordata.c ****     do {
  57:Core/Src/sensordata.c ****         status = Custom_STM_App_Update_Char_Variable_Length(CUSTOM_STM_DP, pageBuffer + 128, 128);
  58:Core/Src/sensordata.c ****         if(status != BLE_STATUS_SUCCESS)
  59:Core/Src/sensordata.c ****             HAL_Delay(10);
  60:Core/Src/sensordata.c ****     } while(status != BLE_STATUS_SUCCESS);
  61:Core/Src/sensordata.c **** }
