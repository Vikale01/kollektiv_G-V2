 252:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     taskENTER_CRITICAL();                                  \
 253:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****     {                                                      \
 254:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         if( ( pxQueue )->cRxLock == queueUNLOCKED )        \
 255:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         {                                                  \
 256:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****             ( pxQueue )->cRxLock = queueLOCKED_UNMODIFIED; \
 257:Middlewares/Third_Party/FreeRTOS/Source/queue.c ****         }                                                  \
