 163:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** 
 164:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** /**
 165:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   * @brief  Program double word or fast program of a row at a specified address.
 166:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   * @note   Before any operation, it is possible to check there is no operation suspended
 167:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   *         by call HAL_FLASHEx_IsOperationSuspended()
 168:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   * @param  TypeProgram Indicate the way to program at a specified address
 169:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   *                       This parameter can be a value of @ref FLASH_TYPE_PROGRAM
 170:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   * @param  Address Specifies the address to be programmed.
 171:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   * @param  Data Specifies the data to be programmed
 172:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   *                This parameter is the data for the double word program and the address where
 173:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   *                are stored the data for the row fast program.
 174:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   *
 175:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   * @retval HAL_StatusTypeDef HAL Status
 176:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   */
 177:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** HAL_StatusTypeDef HAL_FLASH_Program(uint32_t TypeProgram, uint32_t Address, uint64_t Data)
 178:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** {
 179:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   HAL_StatusTypeDef status;
 180:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** 
 181:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   /* Check the parameters */
 182:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   assert_param(IS_FLASH_TYPEPROGRAM(TypeProgram));
 183:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   assert_param(IS_ADDR_ALIGNED_64BITS(Address));
 184:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   assert_param(IS_FLASH_PROGRAM_ADDRESS(Address));
 185:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** 
 186:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   /* Process Locked */
 187:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   __HAL_LOCK(&pFlash);
 188:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** 
 189:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   /* Reset error code */
 190:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   pFlash.ErrorCode = HAL_FLASH_ERROR_NONE;
 191:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** 
 192:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   /* Verify that next operation can be proceed */
 193:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   status = FLASH_WaitForLastOperation(FLASH_TIMEOUT_VALUE);
 194:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** 
 195:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   if (status == HAL_OK)
