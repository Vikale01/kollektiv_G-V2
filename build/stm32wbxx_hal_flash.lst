 469:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** HAL_StatusTypeDef HAL_FLASH_Lock(void)
 470:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** {
 471:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   HAL_StatusTypeDef status = HAL_OK;
 472:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** 
 473:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   /* Set the LOCK Bit to lock the FLASH Registers access */
 474:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   /* @Note  The lock and unlock procedure is done only using CR registers even from CPU2 */
 475:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   SET_BIT(FLASH->CR, FLASH_CR_LOCK);
 476:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** 
 477:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   /* verify Flash is locked */
