 604:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** HAL_StatusTypeDef FLASH_WaitForLastOperation(uint32_t Timeout)
 605:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** {
 606:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   uint32_t error;
 607:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   uint32_t tickstart = HAL_GetTick();
 608:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c **** 
 609:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   /* Wait for the FLASH operation to complete by polling on BUSY flag to be reset.
 610:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****      Even if the FLASH operation fails, the BUSY flag will be reset and an error
 611:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****      flag will be set */
 612:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   while (__HAL_FLASH_GET_FLAG(FLASH_FLAG_BSY))
 613:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****   {
 614:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****     if ((HAL_GetTick() - tickstart) >= Timeout)
 615:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_flash.c ****     {
