1809:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c **** /**
1810:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   * @brief  Configure the TIM commutation event sequence.
1811:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   * @note  This function is mandatory to use the commutation event in order to
1812:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *        update the configuration at each commutation detection on the TRGI input of the Timer,
1813:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *        the typical use of this feature is with the use of another Timer(interface Timer)
1814:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *        configured in Hall sensor interface, this interface Timer will generate the
1815:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *        commutation at its TRGO output (connected to Timer used in this function) each time
1816:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *        the TI1 of the Interface Timer detect a commutation at its input TI1.
1817:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   * @param  htim TIM handle
1818:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   * @param  InputTrigger the Internal trigger corresponding to the Timer Interfacing with the Hall 
1819:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *          This parameter can be one of the following values:
1820:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *            @arg TIM_TS_ITR0: Internal trigger 0 selected
1821:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *            @arg TIM_TS_ITR1: Internal trigger 1 selected
1822:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *            @arg TIM_TS_ITR2: Internal trigger 2 selected
1823:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *            @arg TIM_TS_ITR3: Internal trigger 3 selected
1824:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *            @arg TIM_TS_NONE: No trigger is needed
1825:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   * @param  CommutationSource the Commutation Event source
1826:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *          This parameter can be one of the following values:
1827:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *            @arg TIM_COMMUTATION_TRGI: Commutation source is the TRGI of the Interface Timer
1828:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   *            @arg TIM_COMMUTATION_SOFTWARE:  Commutation source is set by software using the COMG
1829:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   * @retval HAL status
1830:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   */
1831:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c **** HAL_StatusTypeDef HAL_TIMEx_ConfigCommutEvent(TIM_HandleTypeDef *htim, uint32_t  InputTrigger,
1832:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****                                               uint32_t  CommutationSource)
1833:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c **** {
1834:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   /* Check the parameters */
1835:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   assert_param(IS_TIM_COMMUTATION_EVENT_INSTANCE(htim->Instance));
1836:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   assert_param(IS_TIM_INTERNAL_TRIGGEREVENT_SELECTION(InputTrigger));
1837:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c **** 
1838:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   __HAL_LOCK(htim);
1839:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c **** 
1840:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   if ((InputTrigger == TIM_TS_ITR0) || (InputTrigger == TIM_TS_ITR1) ||
1841:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****       (InputTrigger == TIM_TS_ITR2) || (InputTrigger == TIM_TS_ITR3))
1842:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   {
1843:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****     /* Select the Input trigger */
1844:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****     htim->Instance->SMCR &= ~TIM_SMCR_TS;
1845:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****     htim->Instance->SMCR |= InputTrigger;
