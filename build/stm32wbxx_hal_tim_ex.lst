1849:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   htim->Instance->CR2 |= TIM_CR2_CCPC;
1850:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****   /* Select the Commutation event source */
