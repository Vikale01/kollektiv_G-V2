2229:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****     }
2230:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****     default:
2231:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_tim_ex.c ****       status = HAL_ERROR;
