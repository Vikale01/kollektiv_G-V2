 521:Utilities/sequencer/stm32_seq.c **** 
 522:Utilities/sequencer/stm32_seq.c **** void UTIL_SEQ_WaitEvt(UTIL_SEQ_bm_t EvtId_bm)
 523:Utilities/sequencer/stm32_seq.c **** {
 524:Utilities/sequencer/stm32_seq.c ****     UTIL_SEQ_bm_t event_waited_id_backup;
 525:Utilities/sequencer/stm32_seq.c ****     UTIL_SEQ_bm_t current_task_idx;
 526:Utilities/sequencer/stm32_seq.c ****     UTIL_SEQ_bm_t wait_task_idx;
 527:Utilities/sequencer/stm32_seq.c ****     /*
 528:Utilities/sequencer/stm32_seq.c ****      * store in local the current_task_id_bm as the global variable CurrentTaskIdx
 529:Utilities/sequencer/stm32_seq.c ****      * may be overwritten in case there are nested call of UTIL_SEQ_Run()
 530:Utilities/sequencer/stm32_seq.c ****      */
 531:Utilities/sequencer/stm32_seq.c ****     current_task_idx = CurrentTaskIdx;
 532:Utilities/sequencer/stm32_seq.c ****     if(UTIL_SEQ_NOTASKRUNNING == CurrentTaskIdx)
 533:Utilities/sequencer/stm32_seq.c ****     {
 534:Utilities/sequencer/stm32_seq.c ****         wait_task_idx = 0u;
 535:Utilities/sequencer/stm32_seq.c ****     }
 536:Utilities/sequencer/stm32_seq.c ****     else
 537:Utilities/sequencer/stm32_seq.c ****     {
 538:Utilities/sequencer/stm32_seq.c ****         wait_task_idx = (uint32_t)1u << CurrentTaskIdx;
 539:Utilities/sequencer/stm32_seq.c ****     }
 540:Utilities/sequencer/stm32_seq.c **** 
