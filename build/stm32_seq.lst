 257:Utilities/sequencer/stm32_seq.c ****         }
 258:Utilities/sequencer/stm32_seq.c **** 
 259:Utilities/sequencer/stm32_seq.c ****         current_task_set = TaskPrio[counter].priority & local_taskmask & SuperMask;
 260:Utilities/sequencer/stm32_seq.c **** 
 261:Utilities/sequencer/stm32_seq.c ****         /*
 262:Utilities/sequencer/stm32_seq.c ****          * The round_robin register is a mask of allowed flags to be evaluated.
 263:Utilities/sequencer/stm32_seq.c ****          * The concept is to make sure that on each round on UTIL_SEQ_Run(), if two same flags are 
 264:Utilities/sequencer/stm32_seq.c ****          * the sequencer does not run always only the first one.
 265:Utilities/sequencer/stm32_seq.c ****          * When a task has been executed, The flag is removed from the round_robin mask.
 266:Utilities/sequencer/stm32_seq.c ****          * If on the next UTIL_SEQ_RUN(), the two same flags are set again, the round_robin mask wi
 267:Utilities/sequencer/stm32_seq.c ****          * mask out the first flag so that the second one can be executed.
 268:Utilities/sequencer/stm32_seq.c ****          * Note that the first flag is not removed from the list of pending task but just masked by
 269:Utilities/sequencer/stm32_seq.c ****          * the round_robin mask
 270:Utilities/sequencer/stm32_seq.c ****          *
 271:Utilities/sequencer/stm32_seq.c ****          * In the check below, the round_robin mask is reinitialize in case all pending
 272:Utilities/sequencer/stm32_seq.c ****          * tasks haven been executed at least once
 273:Utilities/sequencer/stm32_seq.c ****          */
