 637:Utilities/sequencer/stm32_seq.c **** /**
 638:Utilities/sequencer/stm32_seq.c ****   * @brief return the position of the first bit set to 1
 639:Utilities/sequencer/stm32_seq.c ****   * @param Value 32 bit value
 640:Utilities/sequencer/stm32_seq.c ****   * @retval bit position
 641:Utilities/sequencer/stm32_seq.c ****   */
 642:Utilities/sequencer/stm32_seq.c **** uint8_t SEQ_BitPosition(uint32_t Value)
 643:Utilities/sequencer/stm32_seq.c **** {
 644:Utilities/sequencer/stm32_seq.c ****     uint8_t position = 0U;
 645:Utilities/sequencer/stm32_seq.c ****     uint32_t lvalue = Value;
 646:Utilities/sequencer/stm32_seq.c **** 
 647:Utilities/sequencer/stm32_seq.c ****     if ((lvalue & 0xFFFF0000U) == 0U)
 648:Utilities/sequencer/stm32_seq.c ****     {
 649:Utilities/sequencer/stm32_seq.c ****         position  = 16U;
 650:Utilities/sequencer/stm32_seq.c ****         lvalue <<= 16U;
 651:Utilities/sequencer/stm32_seq.c ****     }
 652:Utilities/sequencer/stm32_seq.c ****     if ((lvalue & 0xFF000000U) == 0U)
 653:Utilities/sequencer/stm32_seq.c ****     {
 654:Utilities/sequencer/stm32_seq.c ****         position +=  8U;
 655:Utilities/sequencer/stm32_seq.c ****         lvalue <<=  8U;
 656:Utilities/sequencer/stm32_seq.c ****     }
 657:Utilities/sequencer/stm32_seq.c ****     if ((lvalue & 0xF0000000U) == 0U)
 658:Utilities/sequencer/stm32_seq.c ****     {
 659:Utilities/sequencer/stm32_seq.c ****         position +=  4U;
 660:Utilities/sequencer/stm32_seq.c ****         lvalue <<=  4U;
 661:Utilities/sequencer/stm32_seq.c ****     }
 662:Utilities/sequencer/stm32_seq.c **** 
 663:Utilities/sequencer/stm32_seq.c ****     position += SEQ_clz_table_4bit[lvalue >> (32-4)];
 664:Utilities/sequencer/stm32_seq.c **** 
 665:Utilities/sequencer/stm32_seq.c ****     return (uint8_t)(31U-position);
 666:Utilities/sequencer/stm32_seq.c **** }
