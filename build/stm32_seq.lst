 295:Utilities/sequencer/stm32_seq.c **** 
 296:Utilities/sequencer/stm32_seq.c ****         task_starving_list &= (~TaskClearList);
 297:Utilities/sequencer/stm32_seq.c **** 
 298:Utilities/sequencer/stm32_seq.c ****         /*
 299:Utilities/sequencer/stm32_seq.c ****          * Consider first the starving list and update current_task_set accordingly
 300:Utilities/sequencer/stm32_seq.c ****          */
 301:Utilities/sequencer/stm32_seq.c ****         if ((task_starving_list & current_task_set) != 0U)
 302:Utilities/sequencer/stm32_seq.c ****         {
 303:Utilities/sequencer/stm32_seq.c ****           current_task_set = (task_starving_list & current_task_set);
 304:Utilities/sequencer/stm32_seq.c ****         }
 305:Utilities/sequencer/stm32_seq.c ****         else
 306:Utilities/sequencer/stm32_seq.c ****         {
