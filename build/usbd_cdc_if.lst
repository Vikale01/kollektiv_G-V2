 260:USB_Device/App/usbd_cdc_if.c **** /**
 261:USB_Device/App/usbd_cdc_if.c ****   * @brief  Data received over USB OUT endpoint are sent over CDC interface
 262:USB_Device/App/usbd_cdc_if.c ****   *         through this function.
 263:USB_Device/App/usbd_cdc_if.c ****   *
 264:USB_Device/App/usbd_cdc_if.c ****   *         @note
 265:USB_Device/App/usbd_cdc_if.c ****   *         This function will issue a NAK packet on any OUT packet received on
 266:USB_Device/App/usbd_cdc_if.c ****   *         USB endpoint until exiting this function. If you exit this function
 267:USB_Device/App/usbd_cdc_if.c ****   *         before transfer is complete on CDC interface (ie. using DMA controller)
 268:USB_Device/App/usbd_cdc_if.c ****   *         it will result in receiving more data while previous ones are still
 269:USB_Device/App/usbd_cdc_if.c ****   *         not sent.
 270:USB_Device/App/usbd_cdc_if.c ****   *
 271:USB_Device/App/usbd_cdc_if.c ****   * @param  Buf: Buffer of data to be received
 272:USB_Device/App/usbd_cdc_if.c ****   * @param  Len: Number of data received (in bytes)
 273:USB_Device/App/usbd_cdc_if.c ****   * @retval Result of the operation: USBD_OK if all operations are OK else USBD_FAIL
 274:USB_Device/App/usbd_cdc_if.c ****   */
 275:USB_Device/App/usbd_cdc_if.c **** static int8_t CDC_Receive_FS(uint8_t* Buf, uint32_t *Len)
 276:USB_Device/App/usbd_cdc_if.c **** {
 277:USB_Device/App/usbd_cdc_if.c ****   /* USER CODE BEGIN 6 */
 278:USB_Device/App/usbd_cdc_if.c ****   USBD_CDC_SetRxBuffer(&hUsbDeviceFS, &Buf[0]);
 279:USB_Device/App/usbd_cdc_if.c ****   USBD_CDC_ReceivePacket(&hUsbDeviceFS);
 280:USB_Device/App/usbd_cdc_if.c ****   return (USBD_OK);
 281:USB_Device/App/usbd_cdc_if.c ****   /* USER CODE END 6 */
 282:USB_Device/App/usbd_cdc_if.c **** }
 283:USB_Device/App/usbd_cdc_if.c **** 
 284:USB_Device/App/usbd_cdc_if.c **** /**
 285:USB_Device/App/usbd_cdc_if.c ****   * @brief  CDC_Transmit_FS
 286:USB_Device/App/usbd_cdc_if.c ****   *         Data to send over USB IN endpoint are sent over CDC interface
 287:USB_Device/App/usbd_cdc_if.c ****   *         through this function.
 288:USB_Device/App/usbd_cdc_if.c ****   *         @note
 289:USB_Device/App/usbd_cdc_if.c ****   *
 290:USB_Device/App/usbd_cdc_if.c ****   *
ARM GAS  C:\Users\bku598\AppData\Local\Temp\ccm4OB6o.s 			page 9


 291:USB_Device/App/usbd_cdc_if.c ****   * @param  Buf: Buffer of data to be sent
 292:USB_Device/App/usbd_cdc_if.c ****   * @param  Len: Number of data to be sent (in bytes)
 293:USB_Device/App/usbd_cdc_if.c ****   * @retval USBD_OK if all operations are OK else USBD_FAIL or USBD_BUSY
 294:USB_Device/App/usbd_cdc_if.c ****   */
 295:USB_Device/App/usbd_cdc_if.c **** uint8_t CDC_Transmit_FS(uint8_t* Buf, uint16_t Len)
 296:USB_Device/App/usbd_cdc_if.c **** {
 297:USB_Device/App/usbd_cdc_if.c ****   uint8_t result = USBD_OK;
 298:USB_Device/App/usbd_cdc_if.c ****   /* USER CODE BEGIN 7 */
 299:USB_Device/App/usbd_cdc_if.c ****   USBD_CDC_HandleTypeDef *hcdc = (USBD_CDC_HandleTypeDef*)hUsbDeviceFS.pClassData;
 300:USB_Device/App/usbd_cdc_if.c ****   if (hcdc->TxState != 0){
