 302:USB_Device/App/usbd_cdc_if.c ****   }
 303:USB_Device/App/usbd_cdc_if.c ****   USBD_CDC_SetTxBuffer(&hUsbDeviceFS, Buf, Len);
 304:USB_Device/App/usbd_cdc_if.c ****   result = USBD_CDC_TransmitPacket(&hUsbDeviceFS);
 305:USB_Device/App/usbd_cdc_if.c ****   /* USER CODE END 7 */
 306:USB_Device/App/usbd_cdc_if.c ****   return result;
 307:USB_Device/App/usbd_cdc_if.c **** }
