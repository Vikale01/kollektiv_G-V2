1023:STM32_WPAN/App/app_ble.c **** const uint8_t* BleGetBdAddress(void)
1024:STM32_WPAN/App/app_ble.c **** {
1025:STM32_WPAN/App/app_ble.c ****   uint8_t *p_otp_addr;
1026:STM32_WPAN/App/app_ble.c ****   const uint8_t *p_bd_addr;
