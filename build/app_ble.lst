1037:STM32_WPAN/App/app_ble.c **** 
1038:STM32_WPAN/App/app_ble.c ****     /**
1039:STM32_WPAN/App/app_ble.c ****      * Public Address with the ST company ID
1040:STM32_WPAN/App/app_ble.c ****      * bit[47:24] : 24bits (OUI) equal to the company ID
1041:STM32_WPAN/App/app_ble.c ****      * bit[23:16] : Device ID.
1042:STM32_WPAN/App/app_ble.c ****      * bit[15:0] : The last 16bits from the UDN
1043:STM32_WPAN/App/app_ble.c ****      * Note: In order to use the Public Address in a final product, a dedicated
1044:STM32_WPAN/App/app_ble.c ****      * 24bits company ID (OUI) shall be bought.
1045:STM32_WPAN/App/app_ble.c ****      */
1046:STM32_WPAN/App/app_ble.c ****     a_BdAddrUdn[0] = (uint8_t)(udn & 0x000000FF);
1047:STM32_WPAN/App/app_ble.c ****     a_BdAddrUdn[1] = (uint8_t)((udn & 0x0000FF00) >> 8);
1048:STM32_WPAN/App/app_ble.c ****     a_BdAddrUdn[2] = (uint8_t)device_id;
1049:STM32_WPAN/App/app_ble.c ****     a_BdAddrUdn[3] = (uint8_t)(company_id & 0x000000FF);
1050:STM32_WPAN/App/app_ble.c ****     a_BdAddrUdn[4] = (uint8_t)((company_id & 0x0000FF00) >> 8);
1051:STM32_WPAN/App/app_ble.c ****     a_BdAddrUdn[5] = (uint8_t)((company_id & 0x00FF0000) >> 16);
1052:STM32_WPAN/App/app_ble.c **** 
1053:STM32_WPAN/App/app_ble.c ****     p_bd_addr = (const uint8_t *)a_BdAddrUdn;
1054:STM32_WPAN/App/app_ble.c ****   }
1055:STM32_WPAN/App/app_ble.c ****   else
1056:STM32_WPAN/App/app_ble.c ****   {
1057:STM32_WPAN/App/app_ble.c ****     p_otp_addr = OTP_Read(0);
ARM GAS  C:\Users\bku598\AppData\Local\Temp\cc2Xeutf.s 			page 20


1058:STM32_WPAN/App/app_ble.c ****     if (p_otp_addr)
1059:STM32_WPAN/App/app_ble.c ****     {
1060:STM32_WPAN/App/app_ble.c ****       p_bd_addr = ((OTP_ID0_t*)p_otp_addr)->bd_address;
1061:STM32_WPAN/App/app_ble.c ****     }
1062:STM32_WPAN/App/app_ble.c ****     else
1063:STM32_WPAN/App/app_ble.c ****     {
