1030:STM32_WPAN/App/app_ble.c **** 
1031:STM32_WPAN/App/app_ble.c ****   udn = LL_FLASH_GetUDN();
1032:STM32_WPAN/App/app_ble.c **** 
1033:STM32_WPAN/App/app_ble.c ****   if (udn != 0xFFFFFFFF)
1034:STM32_WPAN/App/app_ble.c ****   {
1035:STM32_WPAN/App/app_ble.c ****     company_id = LL_FLASH_GetSTCompanyID();
