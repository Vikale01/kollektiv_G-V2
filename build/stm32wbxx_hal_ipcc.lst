 502:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c **** void HAL_IPCC_TX_IRQHandler(IPCC_HandleTypeDef *const hipcc)
 503:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c **** {
 504:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   uint32_t irqmask;
 505:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   uint32_t bit_pos;
 506:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   uint32_t ch_count = 0U;
 507:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   IPCC_CommonTypeDef *currentInstance = IPCC_C1;
 508:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c **** 
 509:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   /* check the Tx free channels which are not masked */
 510:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   irqmask = ~(currentInstance->MR) & IPCC_ALL_TX_BUF;
 511:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   irqmask = irqmask & ~(currentInstance->SR << IPCC_MR_CH1FM_Pos);
 512:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c **** 
 513:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   while (irqmask != 0UL)  /* if several bits are set, it loops to serve all of them */
 514:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   {
 515:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****     bit_pos = 1UL << (IPCC_MR_CH1FM_Pos + (ch_count & CHANNEL_INDEX_MASK));
 516:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c **** 
 517:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****     if ((irqmask & bit_pos) != 0U)
 518:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****     {
 519:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****       /* mask the channel Free interrupt  */
 520:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****       currentInstance->MR |= bit_pos;
 521:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****       if (hipcc->ChannelCallbackTx[ch_count] != NULL)
 522:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****       {
 523:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****         hipcc->ChannelCallbackTx[ch_count](hipcc, ch_count, IPCC_CHANNEL_DIR_TX);
 524:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****       }
 525:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****       irqmask =  irqmask & ~(bit_pos);
 526:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****     }
 527:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****     ch_count++;
 528:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c ****   }
 529:Drivers/STM32WBxx_HAL_Driver/Src/stm32wbxx_hal_ipcc.c **** }
