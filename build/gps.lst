  41:Core/Src/gps.c ****     }
  42:Core/Src/gps.c ****     if((ck_a == p[98]) && (ck_b == p[99])) return 1;
  43:Core/Src/gps.c ****     return 0;
  44:Core/Src/gps.c **** }
